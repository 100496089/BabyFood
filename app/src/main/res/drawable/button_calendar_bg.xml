<?xml version="1.0" encoding="utf-8"?>
<!-- ayuda IA (COPILOT) + https://codea.app/blog/diseno-de-un-boton -->
<!--Definimos apariencia visual del botón de añadir comida-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle"> <!--Definimos la forma del botón-->

    <solid android:color="@color/buttonCalendar"/> <!--Color que usamos-->
    <corners android:radius="8dp"/> <!--Esquinas redondeadas-->
    <padding
        android:left="12dp"
        android:top="8dp"
        android:right="12dp"
        android:bottom="8dp"/> <!--Espacio entre borde y texto-->
</shape>
