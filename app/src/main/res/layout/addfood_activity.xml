<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    tools:context=".AddFoodActivity"
    android:background="#EFDAF8">

    <TextView
        android:id="@+id/addFood"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text= "@string/AddFood_Button"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginTop="70dp"
        android:textSize= "25sp"
        android:textStyle= "bold"
        />

    <EditText
        android:id="@+id/photo"
        android:inputType="text"
        android:layout_width="370dp"
        android:layout_height="60dp"
        app:layout_constraintTop_toBottomOf="@id/addFood"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="70dp"
        android:hint="@string/photo" />

    <ImageButton
        android:id="@+id/camera_button"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:scaleType="centerInside"
        android:background="@null"
        android:src="@drawable/camera"
        app:layout_constraintTop_toBottomOf="@id/addFood"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="80dp"
        android:layout_marginEnd="30dp"/>

     <EditText
        android:id="@+id/Name"
        android:inputType="text"
        android:layout_width="370dp"
        android:layout_height="60dp"
        app:layout_constraintTop_toBottomOf="@id/photo"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="40dp"
        android:hint="@string/name" />

    <EditText
        android:id="@+id/Coment"
        android:inputType="text"
        android:layout_width="370dp"
        android:layout_height="60dp"
        app:layout_constraintTop_toBottomOf="@id/Name"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="40dp"
        android:hint="@string/coment" />

    <EditText
        android:id="@+id/Date"
        android:inputType="text"
        android:layout_width="370dp"
        android:layout_height="60dp"
        app:layout_constraintTop_toBottomOf="@id/Coment"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="40dp"
        android:hint="@string/date" />

    <ImageButton
        android:id="@+id/date_button"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:scaleType="centerInside"
        android:background="@null"
        android:src="@drawable/calendar"
        app:layout_constraintTop_toBottomOf="@id/Coment"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="50dp"
        android:layout_marginEnd="30dp"/>

</androidx.constraintlayout.widget.ConstraintLayout>