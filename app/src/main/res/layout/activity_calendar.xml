<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Ayuda 1 COPILOT-->
    <ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:orientation="vertical"
            android:padding="16dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <CalendarView
                android:id="@+id/calendarView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>

            <TextView
                android:text="Desayuno"
                android:textColor="@color/textDayCalendar"
                android:textSize="20sp"
                android:textStyle="bold"
                android:layout_marginTop="16dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <Button
                style="@style/StyleButtonCalendar"
                android:id="@+id/addBreakfast"
                android:text="+"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <!-- Contenedor donde se mostrarán las comidas del desayuno -->
            <LinearLayout
                android:id="@+id/breakfastLayout"
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>

            <TextView
                android:text="Almuerzo"
                android:textColor="@color/textDayCalendar"
                android:textSize="20sp"
                android:textStyle="bold"
                android:layout_marginTop="16dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <Button
                android:id="@+id/addLunch"
                android:text="+"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <!-- Contenedor donde se mostrarán las comidas del almuerzo -->
            <LinearLayout
                android:id="@+id/lunchLayout"
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>

            <TextView
                android:text="Merienda"
                android:textColor="@color/textDayCalendar"
                android:textSize="20sp"
                android:textStyle="bold"
                android:layout_marginTop="16dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <Button
                android:id="@+id/addSnack"
                android:text="+"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <!-- Contenedor donde se mostrarán las comidas de la merienda -->
            <LinearLayout
                android:id="@+id/snackLayout"
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>

            <TextView
                android:text="Cena"
                android:textColor="@color/textDayCalendar"
                android:textSize="20sp"
                android:textStyle="bold"
                android:layout_marginTop="16dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <Button
                android:id="@+id/addDinner"
                android:text="+"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <!-- Contenedor donde se mostrarán las comidas de la cena -->
            <LinearLayout
                android:id="@+id/dinnerLayout"
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>

        </LinearLayout>
    </ScrollView>
    <!-- Ayuda 1 COPILOT -->

</androidx.constraintlayout.widget.ConstraintLayout>